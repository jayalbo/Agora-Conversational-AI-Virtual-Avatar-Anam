# ------------------------------------------------------------------
# Agora ConvAI credentials
# ------------------------------------------------------------------
# Optional fallbacks for local dev. On public deployments, leave these
# empty so every user is required to bring their own Agora credentials
# through the in-app Settings panel.
NEXT_PUBLIC_AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ------------------------------------------------------------------
# Anam avatar
# ------------------------------------------------------------------
ANAM_API_KEY=
ANAM_AVATAR_ID=

# ------------------------------------------------------------------
# OpenAI LLM
# ------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------------
# ElevenLabs TTS
# ------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# ------------------------------------------------------------------
# Agora SSO (REQUIRED in production)
# ------------------------------------------------------------------
# Gates the demo so only Agora account holders can start sessions,
# and gives us a stable user id to meter per-user quota against.
#
# How to get these:
#   1. Ask the Agora SSO admin team (e.g. sunmingda) to register this
#      app as an OAuth client. Give them the exact redirect URI you
#      plan to use — for the hosted demo that's:
#        https://agora-conversational-ai-virtual-ava.vercel.app/api/auth/agora/callback
#   2. They send back a client id + client secret. Paste them below.
#   3. Put the SAME redirect URI into AGORA_SSO_REDIRECT_URI — it must
#      match byte-for-byte, otherwise the token exchange fails.
#
# On Vercel: add these in Project Settings → Environment Variables for
# every environment (Production, Preview, Development) you want to
# support login in.
AGORA_SSO_CLIENT_ID=
AGORA_SSO_CLIENT_SECRET=
AGORA_SSO_REDIRECT_URI=https://agora-conversational-ai-virtual-ava.vercel.app/api/auth/agora/callback
# Override only if pointing at a non-default SSO cluster (staging,
# China cluster at https://sso.shengwang.cn, etc.).
# AGORA_SSO_BASE_URL=https://sso2.agora.io
# AGORA_SSO_OPEN_API_BASE=https://sso-open.agora.io/api-docs/v1

# ------------------------------------------------------------------
# Session JWT signing secret (REQUIRED)
# ------------------------------------------------------------------
# Used to sign the `yan_session` cookie we mint after a successful SSO
# login. Must be at least 32 characters — we enforce this at runtime.
# Generate a fresh one with:
#   openssl rand -hex 48
# Never reuse this secret across projects; rotating it invalidates
# every active session, which is exactly what you want after a leak.
SESSION_JWT_SECRET=

# ------------------------------------------------------------------
# Auth / quota settings
# ------------------------------------------------------------------
# "sso"    → full Agora SSO login (required in production).
# "bypass" → skip auth entirely, everyone is treated as a local dev
#            user. Ignored when NODE_ENV=production UNLESS you also
#            set ALLOW_BYPASS_IN_PRODUCTION=true (see below). This
#            double-opt-in is intentional — `bypass` on a public
#            deployment makes the demo unauthenticated.
AUTH_MODE=sso

# Escape hatch for deploying with AUTH_MODE=bypass on Vercel/other
# production hosts BEFORE the SSO credentials are ready. When set to
# "true", the NODE_ENV=production guard on bypass is disabled and
# every visitor is treated as the synthetic DEV_USER. Every request
# logs a loud warning so this state is visible in `vercel logs`.
# Remove once you've wired AGORA_SSO_* and switched AUTH_MODE back to
# "sso".
# ALLOW_BYPASS_IN_PRODUCTION=false

# Per-account time budget in seconds. Defaults to 600 (10 minutes).
# Applies to every user who is NOT on the bypass list below.
DEMO_QUOTA_SECONDS=600

# Comma-separated list of Agora user ids OR email addresses that skip
# the per-account quota and see an "Unlimited" badge instead of a
# countdown timer. Match is case-insensitive; use it for whoever is
# presenting the demo live so they don't get cut off mid-pitch.
# Example:
#   QUOTA_BYPASS_ACCOUNTS=yan@agora.io,your-agora-email@agora.io
QUOTA_BYPASS_ACCOUNTS=

# ------------------------------------------------------------------
# Upstash Redis (quota storage). Populated automatically when you
# link the "Upstash for Redis" integration on Vercel (Storage →
# Marketplace → Upstash for Redis). For local dev, create a free
# Upstash database and paste the REST URL + token below.
# ------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
